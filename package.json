{
  "name": "bravado-server",
  "version": "1.6.0",
  "description": "Server for the Bravado REST API framework",
  "directories": {
    "lib": "lib"
  },
  "type": "module",
  "scripts": {
    "reinstall": "rm -rf node_modules && yarn install",
    "lint": "eslint .",
    "lint:fix": "yarn lint --fix",
    "lint:changed": "lint-staged",
    "test": "JWT_ALGO=HS256 JWT_SECRET='ssshhh' mocha test/index-spec.js --timeout 15000"
  },
  "engines": {
    "node": ">=20"
  },
  "main": "lib/index.js",
  "author": "Losant <hello@losant.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/Losant/bravado-server/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Losant/bravado-server.git"
  },
  "keywords": [
    "rest",
    "restful",
    "server",
    "api",
    "bravado"
  ],
  "lint-staged": {
    "*.js": "eslint"
  },
  "dependencies": {
    "bravado-core": "Losant/bravado-core#housekeeping",
    "bunyan": "^1.8.15",
    "commander": "^14.0.1",
    "convict": "^6.2.3",
    "debug": "^4.4.3",
    "dotenv": "^17.2.3",
    "omnibelt": "^4.0.0",
    "restify": "^11.1.0"
  },
  "devDependencies": {
    "@losant/eslint-config-losant": "^2.0.1",
    "bravado-client-generator": "Losant/bravado-client-generator#master",
    "es6-promise": "^4.2.8",
    "eventsource": "^4.0.0",
    "fs-extra": "^11.3.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.3",
    "mocha": "^11.7.4",
    "nock": "^14.0.10",
    "should": "^13.2.3"
  }
}
