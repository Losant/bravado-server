{
  "name": "bravado-server",
  "version": "1.7.0",
  "description": "Server for the Bravado REST API framework",
  "directories": {
    "lib": "lib"
  },
  "type": "module",
  "scripts": {
    "reinstall": "rm -rf node_modules && pnpm install",
    "lint": "eslint .",
    "lint:fix": "pnpm lint --fix",
    "lint:changed": "lint-staged",
    "test": "JWT_ALGO=HS256 JWT_SECRET='ssshhh' mocha test/index-spec.js --timeout 15000"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@10.33.2",
  "main": "lib/index.js",
  "author": "Losant <hello@losant.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/Losant/bravado-server/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Losant/bravado-server.git"
  },
  "keywords": [
    "rest",
    "restful",
    "server",
    "api",
    "bravado"
  ],
  "lint-staged": {
    "*.js": "eslint"
  },
  "dependencies": {
    "bravado-core": "^0.18.0",
    "bunyan": "^1.8.15",
    "commander": "^14.0.3",
    "convict": "^6.2.5",
    "debug": "^4.4.3",
    "dotenv": "^17.4.2",
    "omnibelt": "^4.1.0",
    "restify": "^11.1.0"
  },
  "devDependencies": {
    "@losant/eslint-config-losant": "^2.1.0",
    "bravado-client-generator": "github:Losant/bravado-client-generator#master",
    "es6-promise": "^4.2.8",
    "eventsource": "^4.1.0",
    "fs-extra": "^11.3.5",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "mocha": "^11.7.6",
    "nock": "^14.0.15",
    "should": "^13.2.3"
  },
  "eslintConfig": {
    "extends": "@losant/eslint-config-losant/env/esm"
  },
  "eslintIgnore": [
    "test/testClient"
  ],
  "pnpm": {
    "overrides": {
      "http-deceiver@^1.2.7": "npm:http-deceiver-fixes@^1.2.8"
    }
  }
}
